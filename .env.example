# Database
SKILLFIT_DATABASE_URL=sqlite:///./backend/skillfit.db

# Admin
SKILLFIT_ADMIN_TOKEN=skillfit-admin
SKILLFIT_ADMIN_USERNAME=admin@skillfit.in
SKILLFIT_ADMIN_PASSWORD=skillfit2024

# Allowed CORS origins (JSON array)
SKILLFIT_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost"]

# Sarvam AI (ASR for Kannada and Hindi)
SKILLFIT_SARVAM_API_KEY=your_sarvam_api_key_here

# OpenAI (Whisper ASR for English + GPT-4o-mini assessment)
SKILLFIT_OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude assessment — used when LLM_PROVIDER=claude)
SKILLFIT_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM provider for response assessment: "claude" or "openai"
# When set to "claude", ANTHROPIC_API_KEY must be provided.
# Falls back to "openai" if the Claude call fails.
SKILLFIT_LLM_PROVIDER=claude
